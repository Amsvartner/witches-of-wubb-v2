WS_SERVER_PORT=3335
VITE_WS_SERVER_PORT=$WS_SERVER_PORT
VITE_WS_SERVER_ADDRESS='localhost'
OSC_SERVER_PORT=9000
LIGHTING_SERVER_ADDRESS='127.0.0.1'
LIGHTING_SERVER_PORT=9001

# WOW-032: optional overrides for ableton-js startup diagnostics. Both have code
# defaults (45s timeout; ~/Music/Ableton/User Library/Remote Scripts/AbletonJS/version.py)
# and only need setting if your machine's paths/timing differ.
# ABLETON_START_TIMEOUT_MS=45000
# ABLETON_REMOTE_SCRIPT_VERSION_PATH=/path/to/Remote Scripts/AbletonJS/version.py

# WOW-007C: 0-based index of the Live set's drum-rack ("cauldron sample")
# track, after the four pillar tracks (0-3). Its clips should be short
# one-shots; its mixer volume doubles as the cauldron loudness control. Unset
# or invalid (non-integer/negative) disables the cauldron-tap and cauldron-
# volume features cleanly (backend logs a warning at startup) - it does not
# block the rest of the installation.
DRUM_RACK_TRACK_INDEX=4
