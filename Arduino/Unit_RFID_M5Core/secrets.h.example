// Copy this file to secrets.h (same directory) and fill in the real values.
// secrets.h is gitignored — see ../../.gitignore — and must never be committed.
// (Wi-Fi credentials stay hardcoded in the sketch until WOW-028 lands and
// moves them here; this file currently holds only the device's pillar
// identity.)
#pragma once

// This device's pillar identity (WOW-030). The backend derives which pillar a
// tag event came from by matching the sender's IP against the frozen map in
// backend/event/IncomingEvents.ts — see docs/HARDWARE_INTEGRATION.md for the
// full table and the flash-time checklist. Set PILLAR_IP to the address that
// matches whichever pillar THIS PHYSICAL DEVICE is being flashed for:
//
//   Pillar 0 -> 192.168.0.101        Pillar 2 -> 192.168.0.103
//   Pillar 1 -> 192.168.0.102        Pillar 3 -> 192.168.0.104
//
// Getting this wrong doesn't crash anything — it just means the backend
// can't place this device's tags on any pillar. The sketch prints the
// configured IP and its derived pillar (or "UNKNOWN") over serial at
// boot specifically so a mis-flashed device is diagnosable in seconds.
#define PILLAR_IP IPAddress(192, 168, 0, 101)
